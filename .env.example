# Proyecto
PROJECT_NAME=TutorIA Academico
ENVIRONMENT=development
DEBUG=True

# Backend
BACKEND_PORT=8000
DJANGO_SECRET_KEY=change-me-in-local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Base de datos
POSTGRES_DB=tutoria_academico
POSTGRES_USER=tutoria_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# IA futura
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
RETRIEVAL_MIN_SCORE=0.70
RETRIEVAL_MAX_DISTANCE=0.35

# Speech-to-text
STT_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_SPEECH_MODEL=universal-3-pro,universal-2

# Text-to-speech
TTS_PROVIDER=cartesia
CARTESIA_API_KEY=
CARTESIA_LANGUAGE=es
CARTESIA_VOICE_ID=bef24f4f-adc9-4cef-acbf-cc1ceb98224b
CARTESIA_WS_OPEN_TIMEOUT=90

# Voice agent
VOICE_AGENT_ENABLED=True
VOICE_AGENT_TTS_ENABLED=True
VOICE_AGENT_SAMPLE_RATE=16000
VOICE_AGENT_MAX_SECONDS=120
VOICE_AGENT_MAX_SENTENCES=3
VOICE_AGENT_MAX_WORDS=80
VOICE_AGENT_MAX_RESPONSE_SENTENCES=4
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_VOICE_AGENT_SILENCE_MS=1500

# Archivos
MEDIA_ROOT=/app/media
